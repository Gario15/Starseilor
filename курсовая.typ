import bpy

def test_place_objects():
    # Очистка сцены
    bpy.ops.object.select_all(action='SELECT')
    bpy.ops.object.delete()
    
    # Создание кривой
    bpy.ops.curve.primitive_bezier_curve_add()
    curve = bpy.context.active_object
    
    # Создание объекта-шаблона
    bpy.ops.mesh.primitive_cube_add()
    cube = bpy.context.active_object
    cube.name = "TestCube"
    
    # Настройка аддона
    curve.main_object.ObjectsInPoints = cube
    curve.main_object.curv = curve.data
    
    # Размещение объектов
    bpy.ops.object.place_objects()
    
    # Проверка
    coll_name = f"Starselor_{curve.name}"
    coll = bpy.data.collections.get(coll_name)
    
    if coll and len(coll.objects) > 0:
        print(f"Тест пройден: создано {len(coll.objects)} объектов")
        return True
    else:
        print("Тест не пройден: коллекция пуста или не создана")
        return False

if __name__ == "__main__":
    test_place_objects()
